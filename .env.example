# LibreFlow — environment configuration
#
# Copy to `.env` and adjust. In DEVELOPMENT every variable is OPTIONAL — the app
# runs with safe defaults and zero config. In PRODUCTION (NODE_ENV=production) the
# secrets marked REQUIRED must be set or the backend refuses to start.
#
# Node 20.6+ can load this file directly:  node --env-file=.env ...
# (the dev scripts read process.env; export these in your shell or use --env-file)

# ----- Runtime -----
# NODE_ENV=production           # enables strict mode (secrets enforced)
# PORT=3000                     # backend HTTP port (default 3000)
# Path to the SQLite file (+ WAL/-shm + binaries). Point it at a persistent volume in Docker.
# Default: ./database.sqlite next to the backend process. The Docker image sets /data/database.sqlite.
# LF_DB_PATH=/data/database.sqlite
# Directory of the built frontend (frontend/dist) to serve from the backend in single-container
# deploys. Unset in dev (Vite serves the frontend on :5173). The Docker image sets this.
# LF_STATIC_DIR=/app/frontend/dist
# Public base URL of this instance, used to build the OAuth2 redirect_uri
# (<LF_PUBLIC_URL>/oauth/callback) for interactive authorization_code credentials.
# Must match exactly what you register in the provider's OAuth app. Falls back to
# http://localhost:PORT (only works with providers that allow localhost redirects).
# LF_PUBLIC_URL=https://libreflow.example.com

# ----- Secrets (REQUIRED in production) -----
# Master key used to encrypt stored credentials (AES-256-GCM). NEVER use the dev default in prod.
ENCRYPTION_KEY=change-me-to-a-long-random-secret

# API key required on every /api request (header: x-api-key or Authorization: Bearer <key>).
LF_API_KEY=change-me-to-a-long-random-secret

# Secret for verifying inbound webhook HMAC signatures (header: x-libreflow-signature: sha256=<hex>).
LF_WEBHOOK_SECRET=change-me-to-a-long-random-secret

# ----- Multi-user auth (in progress) -----
# Bootstrap admin: si se definen, al arrancar se crea (si no existe) un usuario admin y se le
# asignan los recursos sin dueño. La LF_API_KEY se conserva como llave admin/break-glass.
# LF_ADMIN_EMAIL=admin@example.com
# LF_ADMIN_PASSWORD=change-me-strong
# Secreto para firmar los JWT de sesión (HS256). REQUIRED en producción cuando se active auth.
# LF_JWT_SECRET=change-me-to-a-long-random-secret

# Max wait (ms) for a SYNCHRONOUS webhook (trigger responseMode = lastNode/respondNode)
# before returning 504. The workflow keeps running in the background. Default 30000.
# LF_WEBHOOK_SYNC_TIMEOUT_MS=30000

# ----- Hardening (optional; sensible defaults) -----
# Comma-separated CORS allowlist. Unset = permissive (dev only).
# LF_CORS_ORIGINS=https://app.example.com,https://admin.example.com

# Max JSON request body size (default 1mb).
# LF_BODY_LIMIT=1mb

# Global rate limit (default 300 requests / 60000 ms per IP).
# LF_RATE_MAX=300
# LF_RATE_WINDOW_MS=60000

# Allow outbound requests to private/loopback IPs (SSRF guard).
# Default: allowed in dev, blocked in production. Set true to allow local MCP servers in prod.
# LF_ALLOW_PRIVATE_URLS=false

# Oculta de tools/list las tools MCP deprecadas (lecturas reemplazadas por libreflow_query_data).
# Siguen funcionando si un cliente las llama; esto solo aligera la superficie para el agente.
# LF_MCP_HIDE_DEPRECATED=false

# jsCode node: el código del usuario corre en un aislado de isolated-vm (V8 sin acceso al
# host: sin require/fs/process/red). Seguro en producción; no requiere flag de activación.
# Límites configurables del aislado:
# LF_JS_TIMEOUT_MS=5000   # tiempo máximo de ejecución por nodo (ms)
# LF_JS_MEMORY_MB=128     # memoria máxima del aislado (MB)

# Tamaño máximo por binario (descargas/subidas de httpRequest). Los bytes se guardan en
# SQLite y se leen en memoria, así que no es para ficheros enormes.
# LF_MAX_BINARY_MB=16

# Allow per-second (6-field) cron schedules. Default: blocked.
# LF_ALLOW_FAST_CRON=false

# Max node-execution steps before aborting a run (infinite-loop guard, default 100000).
# LF_MAX_EXECUTION_STEPS=100000
